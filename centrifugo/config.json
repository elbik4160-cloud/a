{
  "port": 8000,
  "admin_port": 8001,
  "admin": true,

  "engine": "redis",
  "redis_address": "redis:6379",

  "allowed_origins": [
    "http://localhost:3000",
    "https://your-production-domain.com"
  ],

  "namespaces": [
    {
      "name": "workspace",
      "history_size": 300,
      "history_ttl": "10m",
      "recover": true,
      "presence": true,
      "join_leave": true
    },
    {
      "name": "user",
      "history_size": 100,
      "history_ttl": "5m",
      "recover": true
    },
    {
      "name": "chat",
      "history_size": 500,
      "history_ttl": "24h",
      "recover": true,
      "presence": true,
      "join_leave": true
    },
    {
      "name": "lead",
      "history_size": 50,
      "history_ttl": "5m",
      "recover": true
    }
  ]
}
