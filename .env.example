# Copy this file to .env.local and provide real values before running the app.
# Use a secure random string for BETTER_AUTH_SECRET, such as: npx auth secret
DATABASE_URL=postgres://user:password@localhost:5432/crm
ENCRYPT_KEY=replace-with-a-secure-random-key

# Better Auth configuration
BETTER_AUTH_SECRET=replace-with-a-secure-random-string
AUTH_SECRET=replace-with-a-secure-random-string
# BETTER_AUTH_SECRETS=0:replace-with-a-v1-secret
BETTER_AUTH_URL=http://localhost:3000

# Centrifugo configuration
CENTRIFUGO_API_URL=http://localhost:8000/api
CENTRIFUGO_API_KEY=replace-with-your-centrifugo-api-key
CENTRIFUGO_SECRET=replace-with-your-centrifugo-jwt-secret
NEXT_PUBLIC_CENTRIFUGO_URL=ws://localhost:8000/connection/websocket

# Optional runtime fallbacks for Better Auth base URL
VERCEL_PROJECT_PRODUCTION_URL=your-vercel-app.vercel.app
VERCEL_URL=your-preview-url.vercel.app
V0_RUNTIME_URL=https://your-v0-app.v0.dev
